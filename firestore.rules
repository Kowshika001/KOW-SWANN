rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPairMember(pairId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/pairs/$(pairId))
        && request.auth.uid in get(/databases/$(database)/documents/pairs/$(pairId)).data.members;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /usernames/{usernameLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /pairRequests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow read: if isSignedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow update: if isSignedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow delete: if false;
    }

    match /pairs/{pairId} {
      allow read, update: if isPairMember(pairId);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if isPairMember(pairId);
        allow update, delete: if false;
      }

      match /daily_quiz_answers/{dateKey} {
        allow read, create, update: if isPairMember(pairId);
        allow delete: if false;
      }
    }
  }
}
